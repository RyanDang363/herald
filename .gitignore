# Agent / AI tooling
.claude/
.cursor/

# Python virtualenv
.venv/
venv/
__pycache__/
*.pyc

# uv lock (commit this — teammates need identical deps)
# uv.lock is intentionally NOT gitignored

# Dependencies
node_modules/

# Environment / secrets
.env
.env.*
!.env.example

# Build output
dist/
build/
# Replay artifacts are generated; keep the dir (out/.gitkeep) but ignore its contents.
out/*
!out/.gitkeep

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Internal / hackathon docs — production deploy only needs README.md
**/*.md
!/README.md

# Reference libraries, specs, and agent skills (local dev only)
.agents/
docs/
fetch-ai-documentation/
redis-documentation/
