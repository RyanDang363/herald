# ASI:One LLM API key (Orchestrator reasoning). Leave blank when USE_MOCK=true.
ASIONE_API_KEY=YOUR_API_KEY_HERE

# Redis connection. Leave blank to use the in-memory store (no Redis needed for local dev).
# Redis Cloud format:  redis://default:<password>@<host>:<port>
# Redis Cloud TLS:     rediss://default:<password>@<host>:<port>
REDIS_URL=

# Redis Iris Agent Memory (Orchestrator long-term recall — Phase 7 / "beyond caching").
# Leave all three blank to use NoopMemory (agents still run; no semantic recall).
# Provision at: https://cloud.redis.io/#/agent-memory
AGENT_MEMORY_BASE_URL=https://gcp-us-east4.memory.redis.io
AGENT_MEMORY_STORE_ID=YOUR_STORE_ID_HERE
AGENT_MEMORY_API_KEY=YOUR_STORE_API_KEY_HERE

# fal.ai key for Pika video replay (stretch only). Leave blank if unused.
FAL_KEY=

# Base seed for deterministic agent address derivation.
AGENT_SEED=er-twin-demo-seed

# When true, the Orchestrator returns hardcoded responses instead of calling ASI:One.
# Also forces InMemoryStore and NoopMemory so the demo runs with zero external dependencies.
USE_MOCK=true

# Intake orchestration: "direct" = in-process run_intake (demo-safe default); "async" = uAgent
# message flow (only once the async intake path is built — see docs/decisions/).
INTAKE_MODE=direct

# Path to the master EHR fixture. Default works from the repo root.
# The EHR loader always runs (local file IO — not affected by USE_MOCK).
EHR_MASTER_PATH=fixtures/ehr_master.json
